# Config generated by Ghostty Config

theme = "Material Darker"
background = 211D2A
background-opacity = 1
background-blur = 0

font-family = "JetBrainsMono Nerd Font"
font-style-italic = false
font-style-bold-italic = false
font-size = 15

shell-integration-features = no-cursor,no-sudo,no-title,ssh-env,ssh-terminfo

gtk-titlebar = false

confirm-close-surface = false
window-padding-balance = true
window-padding-x = 0
window-padding-y = 0
window-padding-color = extend

# keybinds https://ghostty.org/docs/config/keybind
keybind = performable:ctrl+c=copy_to_clipboard
keybind = performable:ctrl+v=paste_from_clipboard
keybind = ctrl+shift+v=unbind 

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
